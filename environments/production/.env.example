# ============================================================
# PRODUCTIE ENVIRONMENT - Voorbeeldconfiguratie
# Kopieer naar .env en vul in. Commit .env NOOIT naar git.
# Alle waarden worden uitsluitend via GitHub Secrets ingesteld.
# ============================================================

# Applicatie
APP_ENV=production
APP_VERSION=stable
LOG_LEVEL=warning

# Database (productie-instantie)
DB_HOST=db-production
DB_PORT=5432
DB_NAME=openmrs_prod
DB_USER=openmrs_prod
DB_PASSWORD=CHANGE_ME   # GitHub Secret: DB_PASSWORD_PROD

# OpenMRS
OPENMRS_ADMIN_USER=admin
OPENMRS_ADMIN_PASSWORD=CHANGE_ME   # GitHub Secret: OPENMRS_ADMIN_PASSWORD_PROD

# Feature flags
ENABLE_DEBUG_ENDPOINTS=false
SEED_TEST_DATA=false        # ALTIJD false in productie
ANONYMIZE_DATA=false

# Monitoring
SENTRY_DSN=CHANGE_ME        # GitHub Secret: SENTRY_DSN_PROD

# Extra harden
FORCE_HTTPS=true
SESSION_SECURE=true
