# ============================================================
# TEST ENVIRONMENT - Voorbeeldconfiguratie
# Kopieer naar .env en vul in. Commit .env NOOIT naar git.
# ============================================================

# Applicatie
APP_ENV=test
APP_VERSION=latest
LOG_LEVEL=debug

# Database (test-instantie — NOOIT productiedata)
DB_HOST=db-test
DB_PORT=5432
DB_NAME=openmrs_test
DB_USER=openmrs_test
DB_PASSWORD=CHANGE_ME   # Sla op als GitHub Secret: DB_PASSWORD_TEST

# OpenMRS
OPENMRS_ADMIN_USER=admin
OPENMRS_ADMIN_PASSWORD=CHANGE_ME   # GitHub Secret: OPENMRS_ADMIN_PASSWORD_TEST

# Feature flags
ENABLE_DEBUG_ENDPOINTS=true
SEED_TEST_DATA=true        # Automatisch testdata inladen bij opstart
ANONYMIZE_DATA=true        # Alle data is gesynthetiseerd / geanonimiseerd

# Monitoring
SENTRY_DSN=                # optioneel voor test
